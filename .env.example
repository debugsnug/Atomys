# ════════════════════════════════════════════════════════
#   ATOMYS — Enterprise Goal Tracking Portal
#   Environment Configuration Reference
# ════════════════════════════════════════════════════════
#   Copy this file to .env and fill in your values.
#   NEVER commit your real .env to version control.
# ════════════════════════════════════════════════════════

# ── Database (Turso / libSQL) ────────────────────────────
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret-string"

# ── App URL (used in Teams card deep-links) ──────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ════════════════════════════════════════════════════════
#   BONUS: Microsoft Entra ID (Azure AD) SSO
#   Enables "Sign in with Microsoft" on the login page.
#   Employees are auto-provisioned and org hierarchy synced
#   from Azure AD on first login.
# ════════════════════════════════════════════════════════

# 1. Register an app at https://portal.azure.com → App registrations
# 2. Add redirect URI: http://localhost:3000/api/auth/azure/callback
# 3. Under API permissions, grant: User.Read, GroupMember.Read.All

AZURE_AD_CLIENT_ID="your-azure-app-client-id"
AZURE_AD_TENANT_ID="your-azure-tenant-id"
AZURE_AD_CLIENT_SECRET="your-azure-client-secret"
AZURE_AD_REDIRECT_URI="http://localhost:3000/api/auth/azure/callback"

# Azure AD Security Groups → Role mapping
# Create groups in Azure AD and paste their Display Names here
AZURE_AD_ADMIN_GROUP="ATOMYS-Admins"
AZURE_AD_MANAGER_GROUP="ATOMYS-Managers"
# Any user not in the above groups defaults to EMPLOYEE role

# ════════════════════════════════════════════════════════
#   BONUS: Microsoft Teams Notifications
#   Sends Adaptive Card notifications for:
#     • Goal sheet submitted  → notifies manager
#     • Goal sheet approved   → notifies employee
#     • Goal sheet returned   → notifies employee + feedback
#     • Escalation raised     → notifies HR / skip-level
# ════════════════════════════════════════════════════════

# 1. In Teams: go to the channel → ... → Connectors
# 2. Add "Incoming Webhook" → copy the webhook URL here

TEAMS_WEBHOOK_URL="https://atomberg.webhook.office.com/webhookb2/your-webhook-url"
